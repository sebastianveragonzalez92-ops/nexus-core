{
  "name": "User",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string",
      "description": "ID de la empresa (tenant) a la que pertenece el usuario"
    },
    "is_platform_admin": {
      "type": "boolean",
      "default": false,
      "description": "Administrador global de la plataforma (gestiona todas las empresas)"
    }
  }
}